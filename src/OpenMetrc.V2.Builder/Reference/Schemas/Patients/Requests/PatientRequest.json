  "properties": {
    "LicenseNumber": {
      "type": "string"
    },
    "LicenseEffectiveStartDate": {
      "type": "string",
      "format": "date"
    },
    "LicenseEffectiveEndDate": {
      "type": "string",
      "format": "date"
    },
    "RecommendedPlants": {
      "type": "integer"
    },

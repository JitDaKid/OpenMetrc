{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "PlantManicureplantRequest",
  "type": "object",
  "properties": {
    "Plant": {
      "type": "string"
    },
    "Weight": {
      "type": "number"
    },
    "UnitOfWeight": {
      "type": "string"
    },
    "DryingLocation": {
      "type": "string"
    },
    "DryingSublocation": {
      "type": "string"
    },
    "PatientLicenseNumber": {
      "type": "string"
    },
    "ActualDate": {
      "type": "string",
      "format": "date"
    },
    "PlantCount": {
      "type": "integer"
    },
    "HarvestName": {
      "type": "string",
      "x-nullable": true
    }
  }
}
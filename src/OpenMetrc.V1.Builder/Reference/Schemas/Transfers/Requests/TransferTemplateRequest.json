{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "TransferTemplateRequest",
  "type": "object",
  "properties": {
    "Name": {
      "type": "string"
    },
    "Destinations": {
      "type": "array",
      "items": {
        "title": "Destinations",
        "$ref": "#/definitions/Destination"
      }
    },
    "TransferTemplateId": {
      "type": "integer"
    }
  },
  "definitions": {
    "Transporter": {
      "title": "Transporters",
      "type": "object",
      "properties": {
        "TransporterFacilityLicenseNumber": {
          "type": "string"
        },
        "DriverOccupationalLicenseNumber": {
          "type": "string"
        },
        "DriverName": {
          "type": "string"
        },
        "DriverLicenseNumber": {
          "type": "string"
        },
        "DriverLayoverLeg": {
          "type": "string"
        },
        "PhoneNumberForQuestions": {
          "type": "string"
        },
        "VehicleMake": {
          "type": "string"
        },
        "VehicleModel": {
          "type": "string"
        },
        "VehicleLicensePlateNumber": {
          "type": "string"
        },
        "IsLayover": {
          "type": "boolean"
        },
        "EstimatedDepartureDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "EstimatedArrivalDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "TransporterDetails": {}
      }
    },
    "Package": {
      "title": "Packages",
      "type": "object",
      "properties": {
        "PackageLabel": {
          "type": "string"
        },
        "WholesalePrice": {},
        "GrossWeight": {
          "type": "number"
        },
        "GrossUnitOfWeightName": {
          "type": "string"
        }
      }
    },
    "Destination": {
      "title": "Destinations",
      "type": "object",
      "properties": {
        "RecipientLicenseNumber": {
          "type": "string"
        },
        "InvoiceNumber": {
          "type": "string"
        },
        "TransferTypeName": {
          "type": "string"
        },
        "PlannedRoute": {
          "type": "string"
        },
        "EstimatedDepartureDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "EstimatedArrivalDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "Transporters": {
          "type": "array",
          "items": {
            "title": "Transporters",
            "$ref": "#/definitions/Transporter"
          }
        },
        "Packages": {
          "type": "array",
          "items": {
            "title": "Packages",
            "$ref": "#/definitions/Package"
          }
        }
      }
    }
  }
}